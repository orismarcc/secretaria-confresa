# Supabase public credentials (safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ⚠️  NEVER put SUPABASE_SERVICE_ROLE_KEY here or in any file that gets committed.
# The service role key is used ONLY in Supabase Edge Functions via Deno.env.get()
# and must be set via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
